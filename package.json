{
  "name": "idb-free-sync",
  "version": "0.4.0",
  "description": "Synchronize browser IndexedDB stores with cloud-backed JSON files.",
  "keywords": [
    "indexeddb",
    "sync",
    "google-drive",
    "onedrive",
    "dropbox",
    "webdav"
  ],
  "author": {
    "name": "Rick Carls",
    "email": "richard.j.carls@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/idb-free-sync.cjs",
  "module": "./dist/idb-free-sync.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/idb-free-sync.js",
      "require": "./dist/idb-free-sync.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "check": "yarn format:check && yarn typecheck && yarn build",
    "commitlint": "commitlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "yarn check",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "idb": ">=8"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/gapi": "*",
    "@types/gapi.client.drive-v3": "*",
    "@types/google.accounts": "^0.0.18",
    "idb": "^8.0.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.3.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "packageManager": "yarn@4.14.1",
  "publishConfig": {
    "access": "public"
  },
  "simple-git-hooks": {
    "pre-commit": "yarn format:check",
    "commit-msg": "yarn commitlint --edit \"$1\""
  },
  "dependencies": {
    "@azure/msal-browser": "5.11.0",
    "dropbox": "10.34.0",
    "webdav": "5.10.0"
  }
}
