{
  "name": "idb-free-sync",
  "version": "0.7.3",
  "description": "Synchronize browser IndexedDB stores with cloud-backed JSON files.",
  "keywords": [
    "indexeddb",
    "sync",
    "google-drive",
    "onedrive",
    "dropbox",
    "webdav"
  ],
  "author": {
    "name": "Rick Carls",
    "email": "richard.j.carls@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "module": "./dist/idb-free-sync.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/idb-free-sync.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./google": {
      "types": "./dist/GoogleDriveTransport.d.ts",
      "import": "./dist/google.js"
    },
    "./dropbox": {
      "types": "./dist/DropboxTransport.d.ts",
      "import": "./dist/dropbox.js"
    },
    "./onedrive": {
      "types": "./dist/OneDriveTransport.d.ts",
      "import": "./dist/onedrive.js"
    },
    "./webdav": {
      "types": "./dist/WebDAVTransport.d.ts",
      "import": "./dist/webdav.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "check": "yarn format:check && yarn typecheck && yarn typecheck:test && yarn test:coverage && yarn build && yarn test:package",
    "commitlint": "commitlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "yarn simple-git-hooks",
    "prepublishOnly": "yarn check",
    "release": "yarn build && changeset publish",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:package": "node test/package-exports.mjs",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "version:packages": "changeset version"
  },
  "peerDependencies": {
    "idb": ">=8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nodable/entities": "^2.1.1",
    "@types/gapi": "*",
    "@types/gapi.client.drive-v3": "*",
    "@types/google.accounts": "^0.0.18",
    "@types/node": "^25.9.2",
    "@types/node-fetch": "^2.6.13",
    "@vitest/coverage-v8": "^4.1.8",
    "fake-indexeddb": "^6.2.5",
    "idb": "^8.0.0",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.3.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "yarn@4.14.1",
  "publishConfig": {
    "access": "public"
  },
  "simple-git-hooks": {
    "pre-commit": "yarn format:check",
    "commit-msg": "yarn commitlint --edit \"$1\""
  },
  "dependencies": {
    "@azure/msal-browser": "5.11.0",
    "dropbox": "10.34.0",
    "webdav": "5.10.0"
  },
  "dependenciesMeta": {
    "dropbox@10.34.0": {
      "unplugged": true
    }
  }
}
